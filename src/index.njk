---
layout: layouts/base.njk
permalink: index.html
navKey: home
bodyClass: home-page
title: Jupe Hills Pre & Primary School | Mwanza
description: Jupe Hills Pre & Primary School in Ibaya, Ilalila, Mwanza offers daycare, pre-primary and primary education from Class 1 to Class 6.
ogTitle: Jupe Hills Pre & Primary School
ogDescription: Daycare, pre-primary and primary education in Ibaya, Ilalila, Mwanza. Learners today, leaders tomorrow.
ogImage: /assets/img/field-crossing-960.jpg
ogImageAlt: Jupe Hills pupils walking across the school field with a teacher
---
<section class="hero" aria-label="Welcome">
  <picture>
    <source type="image/webp" srcset="/assets/img/field-crossing-480.webp 480w, /assets/img/field-crossing-960.webp 960w, /assets/img/field-crossing-1600.webp 1600w" sizes="100vw">
    <img class="hero-photo" src="/assets/img/field-crossing-960.jpg" srcset="/assets/img/field-crossing-480.jpg 480w, /assets/img/field-crossing-960.jpg 960w" sizes="100vw" width="1600" height="1067" fetchpriority="high" alt="Pupils in sky-blue tracksuits and maroon shirts walking across the school field with their teacher">
  </picture>
  <div class="hero-content">
    <div class="shell">
      <p class="hero-motto">{{ school.motto }}</p>
      <h1>{{ school.name }}</h1>
      <p class="hero-lede">Daycare, pre-primary and primary education in Ibaya, Ilalila, Mwanza.</p>
      <div class="hero-actions">
        <a class="btn btn--solid" href="{{ school.phones[school.primaryAdmissions.phoneIndex].whatsapp }}">Start an admission enquiry</a>
        <a class="btn btn--ghost" href="tel:{{ school.phones[school.primaryAdmissions.phoneIndex].international }}">Call the school</a>
      </div>
    </div>
  </div>
</section>

<section class="section" aria-labelledby="glance-title">
  <div class="shell">
    <p class="section-kicker">Current school profile</p>
    <h2 class="section-title" id="glance-title">At a glance</h2>
    <dl class="glance">
      <div><dt>Founded</dt><dd>{{ school.founded }}</dd></div>
      <div><dt>Students</dt><dd>{{ school.students }}</dd></div>
      <div><dt>Staff</dt><dd>{{ school.staff }}</dd></div>
      <div><dt>Programmes</dt><dd>3 levels</dd></div>
      <div><dt>School hours</dt><dd>{{ school.hours.time }}</dd></div>
    </dl>
  </div>
</section>

<section class="section" aria-labelledby="about-title">
  <div class="shell split">
    <div>
      <h2 class="section-title" id="about-title">About the school</h2>
      <p>Jupe Hills is a co-educational school in {{ school.address.line1 }}, {{ school.address.line2 }}, {{ school.address.line3 }}.</p>
      <p>We welcome children of all backgrounds, religions and communities, and every child is treated with respect.</p>
      <p>An interview or readiness assessment may be required before class placement. <a href="/about.html">Learn more about our school</a> or <a href="/admissions.html">read how to join us</a>.</p>
    </div>
    <figure>
      <picture>
        <source type="image/webp" srcset="/assets/img/whole-school-trees-480.webp 480w, /assets/img/whole-school-trees-960.webp 960w" sizes="(min-width: 820px) 520px, 92vw">
        <img src="/assets/img/whole-school-trees-960.jpg" srcset="/assets/img/whole-school-trees-480.jpg 480w, /assets/img/whole-school-trees-960.jpg 960w" sizes="(min-width: 820px) 520px, 92vw" width="960" height="640" loading="lazy" alt="Jupe Hills pupils and teachers gathered together beneath trees">
      </picture>
      <figcaption>The Jupe Hills school community together.</figcaption>
    </figure>
  </div>
</section>

<section class="motto-band" aria-label="School motto">
  <svg class="sunburst" viewBox="0 0 100 100" aria-hidden="true" focusable="false">
    <defs><path id="ray" d="M50 50 47.2-8h5.6Z" fill="#f2a93b"></path></defs>
    {% for angle in [0,15,30,45,60,75,90,105,120,135,150,165,180,195,210,225,240,255,270,285,300,315,330,345] %}<use href="#ray" transform="rotate({{ angle }} 50 50)"></use>{% endfor %}
  </svg>
  <p>Learners today,<br><span class="gold">leaders tomorrow.</span></p>
  <p class="attribution">The motto of {{ school.name }}</p>
</section>

<section class="section section--wash" aria-labelledby="programmes-title">
  <div class="shell">
    <h2 class="section-title" id="programmes-title">Programmes</h2>
    <div class="cards">
      {% for programme in school.programmes %}
        <article class="card">
          <h3>{{ programme.name }}</h3>
          {% if programme.classes %}<p class="ages">{{ programme.classes }}</p>{% endif %}
          <p>{{ programme.description }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section" aria-labelledby="life-title">
  <div class="shell">
    <h2 class="section-title" id="life-title">Life at Jupe Hills</h2>
    <p class="measure">School days, school trips and the moments in between.</p>
    <div class="strip" tabindex="0" role="group" aria-label="Photographs of life at Jupe Hills">
      {% set moments = [
        {slug: "saanane-boat", alt: "Pupils in life jackets waving from the Saanane Island boat", caption: "School trip to Saanane Island National Park."},
        {slug: "lunch-tables", alt: "Pupils eating lunch together at green school tables", caption: "Lunch time at school."},
        {slug: "older-pupils", alt: "Older pupils posing together beneath the trees", caption: "Pupils together during the school day."},
        {slug: "enclosure-group", alt: "A teacher with pupils on a school outing", caption: "With a teacher on a school outing."}
      ] %}
      {% for moment in moments %}
        <figure>
          <picture>
            <source type="image/webp" srcset="/assets/img/{{ moment.slug }}-480.webp 480w, /assets/img/{{ moment.slug }}-960.webp 960w" sizes="(min-width: 720px) 340px, 78vw">
            <img src="/assets/img/{{ moment.slug }}-480.jpg" srcset="/assets/img/{{ moment.slug }}-480.jpg 480w, /assets/img/{{ moment.slug }}-960.jpg 960w" sizes="(min-width: 720px) 340px, 78vw" width="960" height="640" loading="lazy" alt="{{ moment.alt }}">
          </picture>
          <figcaption>{{ moment.caption }}</figcaption>
        </figure>
      {% endfor %}
    </div>
    <p><a class="strip-more" href="/gallery.html">See the full gallery <span aria-hidden="true">→</span></a></p>
  </div>
</section>

<section class="section section--wash" aria-labelledby="visit-title">
  <div class="shell">
    <p class="section-kicker">Plan a visit</p>
    <h2 class="section-title" id="visit-title">Visit us</h2>
    {% include "partials/location.njk" %}
  </div>
</section>

{% set ctaTitle = "Ready to visit Jupe Hills?" %}
{% set ctaText = "Ask about a place or arrange a visit to our Ibaya campus." %}
{% set ctaSecondaryUrl = "/admissions.html" %}
{% set ctaSecondaryLabel = "View admissions" %}
{% include "partials/admission-cta.njk" %}
