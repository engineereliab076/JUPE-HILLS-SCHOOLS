{
  "name": "jupe-hills-school-website",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Production-ready website for Jupe Hills Pre & Primary School.",
  "scripts": {
    "dev": "eleventy --serve",
    "build": "eleventy",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:html": "html-validate \"_site/**/*.html\"",
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint:js": "eslint \"js/**/*.js\" \"scripts/**/*.mjs\" \"eleventy.config.js\"",
    "check:links": "node scripts/check-links.mjs",
    "check:a11y": "node scripts/check-a11y.mjs",
    "check:responsive": "node scripts/check-responsive.mjs",
    "audit:lighthouse": "node scripts/lighthouse.mjs",
    "validate": "npm run build && npm run lint:html && npm run lint:css && npm run lint:js && npm run check:links",
    "check": "npm run format:check && npm run validate && npm run check:a11y && npm run check:responsive"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@axe-core/playwright": "^4.10.2",
    "eslint": "^9.32.0",
    "globals": "^16.3.0",
    "html-validate": "^10.2.1",
    "lighthouse": "^12.8.1",
    "playwright": "^1.54.1",
    "prettier": "^3.6.2",
    "stylelint": "^16.22.0",
    "stylelint-config-standard": "^38.0.0"
  }
}
